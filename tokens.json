{
  "$schema": "https://design-tokens.org/schema/v1.0/tokens.schema.json",
  "$description": "Tuff Workwear design tokens. W3C Design Tokens format. Use to sync Figma, generate per-platform configs, or feed Style Dictionary.",
  "color": {
    "brand": {
      "charcoal": { "$value": "#2D2D2D", "$type": "color", "$description": "Primary atmospheric surface" },
      "orange":   { "$value": "#E8611A", "$type": "color", "$description": "Primary action colour" },
      "white":    { "$value": "#FFFFFF", "$type": "color" },
      "grey":     { "$value": "#B0B0B0", "$type": "color" },
      "black":    { "$value": "#111111", "$type": "color" }
    },
    "neutral": {
      "50":  { "$value": "#F7F7F7", "$type": "color" },
      "100": { "$value": "#EDEDED", "$type": "color" },
      "200": { "$value": "#D9D9D9", "$type": "color" },
      "300": { "$value": "#B0B0B0", "$type": "color" },
      "400": { "$value": "#8A8A8A", "$type": "color" },
      "500": { "$value": "#6B6B6B", "$type": "color" },
      "600": { "$value": "#4A4A4A", "$type": "color" },
      "700": { "$value": "#2D2D2D", "$type": "color" },
      "800": { "$value": "#1F1F1F", "$type": "color" },
      "900": { "$value": "#111111", "$type": "color" }
    },
    "orange": {
      "50":  { "$value": "#FFF2EA", "$type": "color" },
      "100": { "$value": "#FCDBC4", "$type": "color" },
      "300": { "$value": "#F19661", "$type": "color" },
      "500": { "$value": "#E8611A", "$type": "color" },
      "600": { "$value": "#CE521A", "$type": "color" },
      "700": { "$value": "#A53F0F", "$type": "color" },
      "800": { "$value": "#7C2E08", "$type": "color" }
    },
    "semantic": {
      "success": {
        "500": { "$value": "#2E8E4A", "$type": "color" },
        "50":  { "$value": "#E5F4EA", "$type": "color" }
      },
      "warning": {
        "500": { "$value": "#C18A00", "$type": "color" },
        "50":  { "$value": "#FBF1D9", "$type": "color" }
      },
      "danger": {
        "500": { "$value": "#B83A2B", "$type": "color" },
        "50":  { "$value": "#F7E1DD", "$type": "color" }
      },
      "info":    { "500": { "$value": "#2D6CB0", "$type": "color" } }
    },
    "hiviz": {
      "yellow": { "$value": "#E5FF00", "$type": "color", "$description": "Photographic accent only. Never used as a UI fill." }
    },
    "role": {
      "surface-page":     { "$value": "{color.brand.white}", "$type": "color" },
      "surface-raised":   { "$value": "{color.brand.white}", "$type": "color" },
      "surface-inverse":  { "$value": "{color.neutral.900}", "$type": "color" },
      "surface-orange":   { "$value": "{color.orange.500}", "$type": "color" },
      "text-primary":     { "$value": "{color.neutral.900}", "$type": "color" },
      "text-secondary":   { "$value": "{color.neutral.500}", "$type": "color" },
      "text-on-orange":   { "$value": "{color.brand.white}", "$type": "color" },
      "border-subtle":    { "$value": "{color.neutral.200}", "$type": "color" },
      "border-strong":    { "$value": "{color.neutral.400}", "$type": "color" },
      "ring-focus":       { "$value": "{color.orange.500}", "$type": "color" }
    }
  },
  "typography": {
    "family": {
      "display": { "$value": "Archivo Black, system-ui, sans-serif", "$type": "fontFamily" },
      "sans":    { "$value": "Inter, system-ui, sans-serif", "$type": "fontFamily" },
      "mono":    { "$value": "JetBrains Mono, ui-monospace, monospace", "$type": "fontFamily" }
    },
    "size": {
      "2xs":         { "$value": "0.6875rem", "$type": "dimension" },
      "xs":          { "$value": "0.75rem",   "$type": "dimension" },
      "sm":          { "$value": "0.875rem",  "$type": "dimension" },
      "base":        { "$value": "1rem",      "$type": "dimension" },
      "md":          { "$value": "1.125rem",  "$type": "dimension" },
      "lg":          { "$value": "1.25rem",   "$type": "dimension" },
      "xl":          { "$value": "1.5rem",    "$type": "dimension" },
      "2xl":         { "$value": "1.875rem",  "$type": "dimension" },
      "3xl":         { "$value": "2.25rem",   "$type": "dimension" },
      "4xl":         { "$value": "3rem",      "$type": "dimension" },
      "5xl":         { "$value": "3.75rem",   "$type": "dimension" },
      "display":     { "$value": "4.5rem",    "$type": "dimension" },
      "display-xl":  { "$value": "6rem",      "$type": "dimension" }
    },
    "lineHeight": {
      "tight":   { "$value": "1.05", "$type": "number" },
      "snug":    { "$value": "1.2",  "$type": "number" },
      "normal":  { "$value": "1.5",  "$type": "number" },
      "relaxed": { "$value": "1.65", "$type": "number" }
    },
    "tracking": {
      "display": { "$value": "-0.02em", "$type": "dimension" },
      "tight":   { "$value": "-0.01em", "$type": "dimension" },
      "normal":  { "$value": "0",       "$type": "dimension" },
      "wide":    { "$value": "0.05em",  "$type": "dimension" },
      "wider":   { "$value": "0.1em",   "$type": "dimension" }
    },
    "weight": {
      "regular":  { "$value": "400", "$type": "fontWeight" },
      "medium":   { "$value": "500", "$type": "fontWeight" },
      "semibold": { "$value": "600", "$type": "fontWeight" },
      "bold":     { "$value": "700", "$type": "fontWeight" },
      "black":    { "$value": "900", "$type": "fontWeight" }
    }
  },
  "spacing": {
    "0":  { "$value": "0px",   "$type": "dimension" },
    "1":  { "$value": "4px",   "$type": "dimension" },
    "2":  { "$value": "8px",   "$type": "dimension" },
    "3":  { "$value": "12px",  "$type": "dimension" },
    "4":  { "$value": "16px",  "$type": "dimension" },
    "6":  { "$value": "24px",  "$type": "dimension" },
    "8":  { "$value": "32px",  "$type": "dimension" },
    "10": { "$value": "40px",  "$type": "dimension" },
    "12": { "$value": "48px",  "$type": "dimension" },
    "16": { "$value": "64px",  "$type": "dimension" },
    "20": { "$value": "80px",  "$type": "dimension" },
    "24": { "$value": "96px",  "$type": "dimension" },
    "32": { "$value": "128px", "$type": "dimension" }
  },
  "radius": {
    "none": { "$value": "0",     "$type": "dimension" },
    "sm":   { "$value": "2px",   "$type": "dimension" },
    "md":   { "$value": "4px",   "$type": "dimension" },
    "lg":   { "$value": "8px",   "$type": "dimension" },
    "pill": { "$value": "9999px","$type": "dimension" }
  },
  "border": {
    "1": { "$value": "1px", "$type": "dimension" },
    "2": { "$value": "2px", "$type": "dimension" },
    "4": { "$value": "4px", "$type": "dimension", "$description": "The brand orange rule width." }
  },
  "shadow": {
    "sm":           { "$value": "0 1px 2px rgba(17,17,17,0.06)", "$type": "shadow" },
    "md":           { "$value": "0 4px 8px rgba(17,17,17,0.08)", "$type": "shadow" },
    "lg":           { "$value": "0 12px 24px rgba(17,17,17,0.12)", "$type": "shadow" },
    "glow-orange":  { "$value": "0 0 24px rgba(232,97,26,0.45)", "$type": "shadow", "$description": "Carries the ad-set price glow into the UI." }
  },
  "motion": {
    "duration": {
      "fast": { "$value": "120ms", "$type": "duration" },
      "base": { "$value": "200ms", "$type": "duration" },
      "slow": { "$value": "360ms", "$type": "duration" }
    },
    "easing": {
      "standard": { "$value": "cubic-bezier(0.2,0,0,1)",   "$type": "cubicBezier" },
      "emphasis": { "$value": "cubic-bezier(0.4,0,0.2,1)", "$type": "cubicBezier" },
      "out":      { "$value": "cubic-bezier(0,0,0.2,1)",   "$type": "cubicBezier" }
    }
  },
  "z": {
    "base":    { "$value": 0,  "$type": "number" },
    "raised":  { "$value": 10, "$type": "number" },
    "sticky":  { "$value": 30, "$type": "number" },
    "overlay": { "$value": 40, "$type": "number" },
    "modal":   { "$value": 50, "$type": "number" },
    "toast":   { "$value": 60, "$type": "number" },
    "tooltip": { "$value": 70, "$type": "number" }
  },
  "icon": {
    "size": {
      "xs":  { "$value": "12px", "$type": "dimension" },
      "sm":  { "$value": "16px", "$type": "dimension" },
      "md":  { "$value": "20px", "$type": "dimension" },
      "lg":  { "$value": "24px", "$type": "dimension" },
      "xl":  { "$value": "32px", "$type": "dimension" },
      "2xl": { "$value": "48px", "$type": "dimension" }
    }
  },
  "breakpoint": {
    "sm":  { "$value": "640px",  "$type": "dimension" },
    "md":  { "$value": "768px",  "$type": "dimension" },
    "lg":  { "$value": "1024px", "$type": "dimension" },
    "xl":  { "$value": "1280px", "$type": "dimension" },
    "2xl": { "$value": "1536px", "$type": "dimension" }
  }
}
